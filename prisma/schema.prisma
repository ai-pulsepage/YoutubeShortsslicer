generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  WHOP
}

enum VideoStatus {
  PENDING
  DOWNLOADING
  TRANSCRIBING
  SEGMENTING
  READY
  FAILED
}

enum SegmentStatus {
  AI_SUGGESTED
  APPROVED
  REJECTED
  RENDERING
  RENDERED
  FAILED
}

enum ShortVideoStatus {
  PENDING
  RENDERING
  RENDERED
  FAILED
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum SubscriptionPlan {
  FREE
  PRO
  AGENCY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── Auth Models (NextAuth) ──────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)

  accounts      Account[]
  sessions      Session[]
  videos        Video[]
  channels      Channel[]
  tags          Tag[]
  subtitlePresets SubtitlePreset[]
  subscription  Subscription?
  schedules     ContentSchedule[]
  documentaries Documentary[]

  // Podcast
  podcastCharacters PodcastCharacter[]
  podcastShows      PodcastShow[]
  podcastSponsors   PodcastSponsor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ─────────────────────────────────────────

model Video {
  id          String      @id @default(cuid())
  userId      String
  sourceUrl   String
  platform    String      // detected platform name
  title       String?
  description String?     @db.Text
  thumbnail   String?
  duration    Int?        // seconds
  status      VideoStatus @default(PENDING)
  storagePath String?     // R2 path
  audioPath   String?     // R2 path for extracted audio
  errorMsg    String?     @db.Text

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcript  Transcript?
  segments    Segment[]
  videoTags   VideoTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transcript {
  id       String @id @default(cuid())
  videoId  String @unique
  content  String @db.Text  // full transcript text
  segments Json   // word-level timestamps [{word, start, end}]

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Segment {
  id          String        @id @default(cuid())
  videoId     String
  startTime   Float         // seconds
  endTime     Float         // seconds
  title       String?
  description String?       @db.Text
  aiScore     Float?        // 0-10 engagement score
  hookStrength Float?       // 0-10
  emotionalArc String?      // e.g. "tension-resolution"
  status      SegmentStatus @default(AI_SUGGESTED)
  voiceoverEnabled Boolean  @default(false)
  voiceoverText    String?  @db.Text
  voiceoverVoice   String?  @default("bm_george")  // Kokoro voice ID
  voiceoverMixMode String?  @default("mix")        // replace | mix | original
  subtitlePresetId String?  // reference to SubtitlePreset

  video       Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  shortVideo  ShortVideo?
  channelFlags ChannelFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShortVideo {
  id            String           @id @default(cuid())
  segmentId     String           @unique
  storagePath   String?          // R2 path to rendered short
  thumbnailPath String?
  subtitleStyle Json?            // snapshot of style used
  duration      Float?           // seconds
  status        ShortVideoStatus @default(PENDING)
  errorMsg      String?          @db.Text

  segment      Segment       @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  publishJobs  PublishJob[]
  draftPosts   DraftPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Channel & Publishing ────────────────────────────────

model Channel {
  id           String   @id @default(cuid())
  userId       String
  platform     Platform
  channelName  String
  channelId    String?  // platform-specific ID
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  tokenExpiry  DateTime?
  isActive     Boolean  @default(true)
  defaults     Json?    // default subtitle style, schedule, description template

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishJobs  PublishJob[]
  draftPosts   DraftPost[]
  channelFlags ChannelFlag[]
  schedules    ContentSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChannelFlag {
  id        String @id @default(cuid())
  segmentId String
  channelId String

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([segmentId, channelId])
}

model PublishJob {
  id              String        @id @default(cuid())
  shortVideoId    String
  channelId       String
  scheduleId      String?       // optional: which schedule this belongs to
  title           String?
  description     String?       @db.Text
  hashtags        String[]
  scheduledAt     DateTime?
  publishedAt     DateTime?
  status          PublishStatus @default(DRAFT)
  platformVideoId String?       // ID on YouTube/Instagram/Whop
  errorMsg        String?       @db.Text

  shortVideo      ShortVideo       @relation(fields: [shortVideoId], references: [id], onDelete: Cascade)
  channel         Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  schedule        ContentSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Content Schedules (Pipelines) ───────────────────────

model ContentSchedule {
  id          String   @id @default(cuid())
  userId      String
  channelId   String
  name        String       // "Animal Clips", "News Shorts"
  description String?
  isActive    Boolean  @default(true)
  postTimes   Json     @default("[\"09:00\",\"13:00\",\"18:00\"]")
  postsPerDay Int      @default(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  publishJobs PublishJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DraftPost {
  id            String  @id @default(cuid())
  shortVideoId  String
  channelId     String
  title         String?
  description   String? @db.Text
  hashtags      String[]
  thumbnailPath String?

  shortVideo ShortVideo @relation(fields: [shortVideoId], references: [id], onDelete: Cascade)
  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Organization ────────────────────────────────────────

model Tag {
  id     String @id @default(cuid())
  name   String
  color  String @default("#3B82F6") // hex color
  userId String

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTags VideoTag[]

  @@unique([name, userId])
}

model VideoTag {
  id      String @id @default(cuid())
  videoId String
  tagId   String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([videoId, tagId])
}

model SubtitlePreset {
  id        String @id @default(cuid())
  userId    String
  name      String
  font      String @default("Montserrat")
  fontSize  Int    @default(48)
  color     String @default("#FFFFFF")
  outline   String @default("#000000")
  shadow    String @default("rgba(0,0,0,0.5)")
  position  String @default("bottom") // top, center, bottom
  animation String @default("word-highlight") // word-highlight, fade, pop
  // AI segmentation defaults for this preset
  segmentMode   String? // e.g. "mini-drama", "suspense", "educational"
  targetMinDuration Int @default(30)
  targetMaxDuration Int @default(58)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Admin ───────────────────────────────────────────────

model ApiKey {
  id        String @id @default(cuid())
  service   String @unique // e.g. "deepseek", "gemini", "together", "whop", "stripe"
  key       String @db.Text // encrypted
  label     String? // human-readable label
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  updatedAt DateTime @updatedAt
}

// ─── Subscription ────────────────────────────────────────

model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  stripeSubscriptionId String?           @unique
  stripeCustomerId    String?
  plan                SubscriptionPlan   @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  trialEnd            DateTime?
  currentPeriodEnd    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Documentary Factory ─────────────────────────────────

enum DocStatus {
  DRAFT
  SCENES_PLANNED
  ASSETS_READY
  GENERATING
  ASSEMBLING
  REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

enum AssetType {
  CHARACTER
  PROP
  CONCEPT
  ENVIRONMENT
  FILLER
}

enum GenJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Documentary {
  id             String    @id @default(cuid())
  userId         String
  title          String?
  sourceUrls     String[]
  rawArticles    Json?
  script         String?   @db.Text
  // ── Genre Preset System ──
  genre          String    @default("science")       // science | true_crime | horror | history | children | sleep | comedy | nature
  subStyle       String    @default("bbc_earth")     // Sub-style within the genre
  audience       String    @default("adults")         // adults | young_adults | kids | toddlers | expert
  perspective    String    @default("omniscient")     // omniscient | first_person | second_person | investigator
  pacing         String    @default("standard")       // slow | standard | fast
  ending         String    @default("ai_decide")      // ai_decide | hopeful | tragic | cliffhanger | reflective | circular | call_to_action
  endingNote     String?                              // Optional free-text ending direction
  contentMode    String    @default("creative")       // factual | creative
  musicMood      String    @default("ambient")        // classical | ambient | dark_ambient | whimsical | epic | piano | electronic | none
  useBRoll       Boolean   @default(true)             // Fetch Pexels stock footage
  useKenBurns    Boolean   @default(true)             // Pan/zoom on images
  visualMode     String    @default("broll_only")     // full_ai_video | chapter_illustrations | broll_only | narration_only
  imageModel     String    @default("chroma")         // chroma | flux | juggernaut
  voiceId        String    @default("Rachel")
  ttsEngine      String    @default("elevenlabs")  // elevenlabs | xtts
  ttsVoiceId     String?                            // Engine-specific voice ID
  narratorStyle  String    @default("sleep")        // sleep | documentary | dramatic | energetic | conversational
  fillerMode     String    @default("kenburns") // kenburns, procedural, stock, kenburns+stock
  status         DocStatus @default(DRAFT)
  totalDuration  Float?
  finalVideoPath String?
  errorMsg       String?   @db.Text

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes         DocScene[]
  assets         DocAsset[]
  genJobs        GenJob[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DocScene {
  id             String   @id @default(cuid())
  documentaryId  String
  sceneIndex     Int
  title          String?
  narrationText  String?  @db.Text
  narrationPath  String?
  duration       Float?
  assembledPath  String?
  searchQueries  String?  @db.Text  // JSON array of AI-generated Pexels search terms

  documentary    Documentary @relation(fields: [documentaryId], references: [id], onDelete: Cascade)
  shots          DocShot[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([documentaryId, sceneIndex])
}

model DocShot {
  id              String   @id @default(cuid())
  sceneId         String
  shotIndex       Int

  // Camera
  shotType        String
  cameraAngle     String?
  cameraMovement  String?

  // Content
  action          String?  @db.Text
  dialogue        String?  @db.Text

  // Mood & Atmosphere
  mood            String?
  lighting        String?
  colorPalette    String?

  // Transition
  transitionIn    String?  @default("cut")
  transitionOut   String?  @default("cut")

  // Generation
  compositePrompt String?  @db.Text
  lastFramePath   String?
  clipPath        String?
  duration        Float?

  scene           DocScene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  shotAssets      DocShotAsset[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sceneId, shotIndex])
}

model DocAsset {
  id             String    @id @default(cuid())
  documentaryId  String
  type           AssetType
  label          String
  description    String?   @db.Text
  attire         String?
  imagePath      String?
  altImages      String[]
  prompt         String?   @db.Text

  documentary    Documentary    @relation(fields: [documentaryId], references: [id], onDelete: Cascade)
  shotAssets     DocShotAsset[]

  createdAt      DateTime @default(now())
}

model DocShotAsset {
  id        String  @id @default(cuid())
  shotId    String
  assetId   String
  role      String?

  shot      DocShot  @relation(fields: [shotId], references: [id], onDelete: Cascade)
  asset     DocAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([shotId, assetId])
}

model GenJob {
  id              String       @id @default(cuid())
  documentaryId   String
  jobType         String
  prompt          String?      @db.Text
  referenceImages String[]
  outputPath      String?
  status          GenJobStatus @default(QUEUED)
  shotId          String?
  assetId         String?
  errorMsg        String?      @db.Text
  metadata        Json?

  documentary     Documentary @relation(fields: [documentaryId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── AI Podcast System ───────────────────────────────────

enum CharacterRole {
  HOST
  GUEST
  WILDCARD
}

enum Archetype {
  FIREBRAND
  PROVOCATEUR
  BULLDOZER
  SNIPER
  PROFESSOR
  PHILOSOPHER
  ANALYST
  SKEPTIC
  COMEDIAN
  STORYTELLER
  WILDCARD_PERSONALITY
  HYPE_MAN
  MEDIATOR
  DEVILS_ADVOCATE
  EMPATH
  ELDER
}

enum Generation {
  SILENT
  BOOMER
  GEN_X
  MILLENNIAL
  GEN_Z
  GEN_ALPHA
}

enum ShowFormat {
  SOLO
  TWO_HOST
  HOST_PLUS_GUESTS
  ROUNDTABLE
}

enum ContentFilter {
  UNHINGED
  MODERATE
  FAMILY_FRIENDLY
}

enum PodcastEpisodeStatus {
  DRAFT
  SCRIPTING
  RECORDING
  ASSEMBLING
  READY
  APPROVED
  PUBLISHED
  REJECTED
  FAILED_PODCAST
}

enum SegmentType {
  INTRO
  TOPIC
  AD_BREAK
  OUTRO
}

enum SourceMode {
  URLS
  AUTO_RESEARCH
  MANUAL_PREMISE
}

enum AdStyle {
  CASUAL
  HYPE
  SINCERE
  COMEDIC
}

enum ImageModel {
  FLUX
  CHROMA
  JUGGERNAUT
}

model PodcastCharacter {
  id                String        @id @default(cuid())
  userId            String
  name              String
  role              CharacterRole @default(GUEST)
  archetype         Archetype     @default(ANALYST)

  // Visual Identity
  avatarUrl         String?
  avatarPrompt      String?       @db.Text
  imageModel        ImageModel    @default(FLUX)

  // Voice
  voiceId           String?                           // ElevenLabs voice ID
  speechRate        Float         @default(1.0)

  // Generation & Worldview
  generation        Generation    @default(MILLENNIAL)
  politicalLeaning  String?       @db.Text
  religiousView     String?       @db.Text
  coreBeliefs       Json          @default("[]")
  hotButtons        Json          @default("[]")

  // Memory
  memories          Json          @default("[]")
  memoryAutoUpdate  Boolean       @default(true)

  // Stats
  episodeCount      Int           @default(0)

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations (join tables)
  showHosts         PodcastShowHost[]
  showDefaultGuests PodcastShowGuest[]
  episodeParticipants EpisodeParticipant[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model PodcastShow {
  id                String        @id @default(cuid())
  userId            String
  name              String
  description       String?       @db.Text
  coverArtUrl       String?
  showFormat        ShowFormat    @default(HOST_PLUS_GUESTS)
  contentFilter     ContentFilter @default(UNHINGED)
  defaultDurationMin Int          @default(30)

  // Jingle
  jingleUrl         String?
  jinglePrompt      String?       @db.Text

  // Distribution
  spotifyRssUrl     String?
  language          String        @default("en")

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hosts             PodcastShowHost[]
  defaultGuests     PodcastShowGuest[]
  episodes          PodcastEpisode[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// Join: Show <-> Host Characters
model PodcastShowHost {
  id          String           @id @default(cuid())
  showId      String
  characterId String

  show        PodcastShow      @relation(fields: [showId], references: [id], onDelete: Cascade)
  character   PodcastCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([showId, characterId])
}

// Join: Show <-> Default Guest Characters
model PodcastShowGuest {
  id          String           @id @default(cuid())
  showId      String
  characterId String

  show        PodcastShow      @relation(fields: [showId], references: [id], onDelete: Cascade)
  character   PodcastCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([showId, characterId])
}

model PodcastEpisode {
  id                String               @id @default(cuid())
  showId            String
  episodeNumber     Int                   @default(0)
  title             String?
  description       String?               @db.Text
  durationMin       Int                   @default(30)
  transcript        Json?                 // Full dialogue turns
  scriptJson        Json?                 // Generated podcast script
  audioUrl          String?
  audioDuration     Float?
  transcriptHtml    String?               @db.Text
  status            PodcastEpisodeStatus  @default(DRAFT)
  errorMsg          String?               @db.Text
  publishedAt       DateTime?

  show              PodcastShow           @relation(fields: [showId], references: [id], onDelete: Cascade)
  segments          EpisodeSegment[]
  participants      EpisodeParticipant[]

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

// Join: Episode <-> Participant Characters
model EpisodeParticipant {
  id          String           @id @default(cuid())
  episodeId   String
  characterId String

  episode     PodcastEpisode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  character   PodcastCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([episodeId, characterId])
}

model EpisodeSegment {
  id            String      @id @default(cuid())
  episodeId     String
  order         Int
  type          SegmentType @default(TOPIC)
  durationMin   Int         @default(10)

  // Topic segments
  topicTitle    String?
  topicContent  String?     @db.Text
  sourceUrls    Json        @default("[]")
  sourceMode    SourceMode  @default(MANUAL_PREMISE)

  // Ad segments
  sponsorId     String?

  // Generated content
  transcript    Json?       // Dialogue for this segment

  episode       PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sponsor       PodcastSponsor? @relation(fields: [sponsorId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([episodeId, order])
}

model PodcastSponsor {
  id            String   @id @default(cuid())
  userId        String
  brandName     String
  tagline       String?
  talkingPoints Json     @default("[]")
  promoCode     String?
  promoUrl      String?
  adStyle       AdStyle  @default(CASUAL)
  adScript      String?  @db.Text
  maxDurationSec Int     @default(60)
  active        Boolean  @default(true)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments      EpisodeSegment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
